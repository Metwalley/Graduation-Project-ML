# Ollama Configuration
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://ollama:11434  # In Docker, use "http://ollama:11434". Local: "http://localhost:11434"

# Embedding Model
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# Knowledge Base
KNOWLEDGE_BASE_PATH=data/articles.json

# RAG Configuration
TOP_K_ARTICLES=3
TEMPERATURE=0.1  # Low temperature for consistent Arabic

# Server Configuration
HOST=0.0.0.0
PORT=8001
APP_MODE=ui  # 'ui' (Streamlit) or 'api' (Back-end Integration)
